# PostgreSQL bağlantısı (Faz 5.0 — zorunlu). Yerel Docker Postgres örneği:
DATABASE_URL=postgresql://postgres:1@localhost:5432/finans

# TEFAS fon fiyatları için RapidAPI anahtarı (opsiyonel).
# https://rapidapi.com/serifcolakel/api/tefas-api — resmi değil, üçüncü taraf aracı.
# Boş bırakılırsa fonlar elle fiyatlanır (Portföy sekmesinde rozet+sıfırla).
RAPIDAPI_KEY=
# İkinci anahtar (opsiyonel) — birinci kota/hız sınırına (429) takılırsa otomatik buna geçilir.
# Aynı hesaptan ikinci bir uygulama/anahtar oluşturarak günlük kotayı ikiye katlayabilirsin.
RAPIDAPI_KEY_2=
