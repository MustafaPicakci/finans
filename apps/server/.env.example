# PostgreSQL bağlantısı (Faz 5.0 — zorunlu). Yerel Docker Postgres örneği:
DATABASE_URL=postgresql://postgres:1@localhost:5432/finans

# TEFAS fon fiyatları için RapidAPI anahtarı (opsiyonel).
# https://rapidapi.com/serifcolakel/api/tefas-api — resmi değil, üçüncü taraf aracı.
# Boş bırakılırsa fonlar elle fiyatlanır (Portföy sekmesinde rozet+sıfırla).
RAPIDAPI_KEY=
# İkinci anahtar (opsiyonel) — birinci kota/hız sınırına (429) takılırsa otomatik buna geçilir.
# Aynı hesaptan ikinci bir uygulama/anahtar oluşturarak günlük kotayı ikiye katlayabilirsin.
RAPIDAPI_KEY_2=

# E-posta gönderimi (Faz 6 — şifre sıfırlama & hesap aktivasyonu). Generic SMTP; boş bırakılırsa
# e-posta gönderilmez, içerik/bağlantı sunucu loguna yazılır (dev). Gmail örneği:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=<gmail adresin>
#   SMTP_PASS=<Google "uygulama parolası" — normal şifre DEĞİL; 2FA açıkken hesap ayarlarından üretilir>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Gönderen görünen adı/adresi (opsiyonel; boşsa "Finans <SMTP_USER>").
MAIL_FROM=
# Uygulamanın herkese açık kök URL'i — e-posta bağlantıları bununla üretilir (ör. https://finans-xxx.onrender.com).
# Boşsa isteğin Origin/host başlığından türetilir (yerelde genelde yeterli).
APP_URL=
