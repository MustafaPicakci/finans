{
  "name": "finans",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"pnpm --filter @finans/server dev\" \"pnpm --filter @finans/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm --filter @finans/engine test",
    "start": "pnpm --filter @finans/server start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
